{
  "name": "web",
  "version": "1.1.8",
  "private": true,
  "scripts": {
    "start": "vite",
    "build": "tsc && vite build",
    "serve": "vite preview",
    "compile": "tsc --noEmit",
    "generate": "cd ../api && uv run python export_openapi.py && cd ../web && kubb generate && rm -f openapi.json",
    "test": "vitest",
    "lint": "biome check --write --no-errors-on-unmatched"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "dependencies": {
    "@equinor/eds-core-react": "^2.3.7",
    "@equinor/eds-icons": "^1.2.0",
    "@equinor/eds-tokens": "^2.1.1",
    "@microsoft/applicationinsights-react-js": "^19.3.8",
    "@microsoft/applicationinsights-web": "^3.3.11",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-oauth2-code-pkce": "^1.24.0",
    "react-router-dom": "^7.13.1",
    "styled-components": "^6.3.11"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.5",
    "@kubb/cli": "^4.31.5",
    "@kubb/core": "^4.31.5",
    "@kubb/plugin-client": "^4.31.5",
    "@kubb/plugin-oas": "^4.31.5",
    "@kubb/plugin-ts": "^4.31.5",
    "@kubb/react-fabric": "^0.13.3",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.3.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "jsdom": "^28.1.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-checker": "^0.12.0",
    "vite-plugin-svgr": "^4.5.0",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.0.18"
  },
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e"
